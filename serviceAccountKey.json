const admin = require("firebase-admin");
const path = require("path");

/**
 * 1. SECURE CREDENTIALS
 * Use a path relative to the current directory or an environment variable.
 * Ensure serviceAccountKey.json is added to your .gitignore!
 */
const serviceAccountPath = process.env.FIREBASE_CONFIG_PATH || "./serviceAccountKey.json";
const serviceAccount = require(path.resolve(__dirname, serviceAccountPath));

/**
 * 2. SINGLETON INITIALIZATION
 * This check prevents the app from trying to initialize twice if the file 
 * is reloaded, which causes a crash in Node.js environments.
 */
if (!admin.apps.length) {
    admin.initializeApp({
        credential: admin.credential.cert(serviceAccount),
        // Optional: Add databaseURL if using Realtime Database
        // databaseURL: "https://your-project-id.firebaseio.com"
    });
    console.log("Firebase Admin initialized.");
}

// 3. Export specific services for easier access in other files
const db = admin.firestore();
const auth = admin.auth();

module.exports = { admin, db, auth };
